# J.GO - configuration
# Copy this file to ".env" (in the project root) and fill in what you need.
# Everything here is optional. The job board works with no keys; AI falls back
# to the Claude CLI when no API key is set. Real environment variables override
# anything set here.

# ---- AI ------------------------------------------------------------
# Option A - bring your own Anthropic API key (https://console.anthropic.com).
# When set, the bridge calls the Anthropic API directly.
ANTHROPIC_API_KEY=
# Optional default model id (used when the app doesn't request a specific one):
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Option B - leave ANTHROPIC_API_KEY empty and use the Claude Code CLI instead
# (Pro/Max subscription, no API key). Install: https://claude.com/claude-code
# CLAUDE_BIN=          # full path to the claude binary, if auto-detection fails
# CLAUDE_MODEL=        # default model alias: haiku | sonnet | opus

# ---- Jobs: Adzuna (optional, free key) -----------------------------
# Adds real on-site listings (UK, US, Canada, DE, NL, AU, ...).
# Free key at https://developer.adzuna.com -> gives you an app id + app key.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRIES=gb,us,ca

# ---- Server --------------------------------------------------------
# BRIDGE_PORT=8787
# BRIDGE_HOST=127.0.0.1   # set 0.0.0.0 to reach it from another device on your LAN
